# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeThisSecretInProduction_VanClinic2025
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# PostgreSQL connection
DATABASE_URL="postgresql://vanclinic:vanclinic_password@127.0.0.1:5432/vanclinic_db?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=ChangeThisPassphraseInProduction
JWT_TOKEN_TTL=3600
JWT_REFRESH_TTL=2592000
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost:1025
MAILER_FROM=noreply@vanclinic.mg
MAILER_FROM_NAME="VanClinic"
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|.*\.vanclinic\.mg)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> SMS Gateway (Madagascar - Orange / Airtel / Telma) ###
SMS_PROVIDER=orange
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_SENDER=VanClinic
###<

###> Mobile Money (Madagascar) ###
ORANGE_MONEY_API_URL=https://api.orange.mg/orange-money-webpay/dev/v1
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key
AIRTEL_MONEY_API_URL=https://openapi.airtel.africa
AIRTEL_MONEY_CLIENT_ID=your_client_id
AIRTEL_MONEY_CLIENT_SECRET=your_client_secret
MVOLA_API_URL=https://api.mvola.mg
MVOLA_CONSUMER_KEY=your_consumer_key
MVOLA_CONSUMER_SECRET=your_consumer_secret
###<

###> File Upload ###
UPLOAD_DIR=%kernel.project_dir%/public/uploads
MAX_UPLOAD_SIZE=10M
###<
