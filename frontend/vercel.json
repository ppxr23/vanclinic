{
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://perceptive-consideration-production-4024.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://perceptive-consideration-production-4024.up.railway.app/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
